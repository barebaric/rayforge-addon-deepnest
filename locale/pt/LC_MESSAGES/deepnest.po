#: deepnest/dialog.py
msgid "Nesting Layout Settings"
msgstr "Configurações de layout de aninhamento"

#: deepnest/dialog.py
msgid "Cancel"
msgstr "Cancelar"

#: deepnest/dialog.py
msgid "Start Nesting"
msgstr "Iniciar aninhamento"

#: deepnest/dialog.py
msgid ""
"Nesting can consume significant memory and take a long time depending on the "
"number and complexity of shapes. It is recommended to start with a small "
"number of shapes before scaling up."
msgstr ""
"O aninhamento pode consumir muita memória e demorar muito tempo dependendo "
"do número e complexidade das formas. É recomendado começar com um pequeno "
"número de formas antes de escalar."

#: deepnest/dialog.py
msgid "Spacing"
msgstr "Espaçamento"

#: deepnest/dialog.py
msgid "Distance between nested shapes"
msgstr "Distância entre formas aninhadas"

#: deepnest/dialog.py
msgid "Constrain Rotation"
msgstr "Restringir rotação"

#: deepnest/dialog.py
msgid "Keep parts in their original orientation"
msgstr "Manter peças na orientação original"

#: deepnest/dialog.py
msgid "Allow Horizontal Flip"
msgstr "Permitir espelhamento horizontal"

#: deepnest/dialog.py
msgid "Mirror parts horizontally for better fit"
msgstr "Espelhar peças horizontalmente para melhor encaixe"

#: deepnest/dialog.py
msgid "Allow Vertical Flip"
msgstr "Permitir espelhamento vertical"

#: deepnest/dialog.py
msgid "Mirror parts vertically for better fit"
msgstr "Espelhar peças verticalmente para melhor encaixe"

#: deepnest/frontend.py
msgid "Auto Layout (Nesting)"
msgstr "Layout automático (Aninhamento)"

#: deepnest/backend.py
msgid "Nesting Layout"
msgstr "Layout de Aninhamento"
