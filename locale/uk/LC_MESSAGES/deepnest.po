#: deepnest/dialog.py
msgid "Nesting Layout Settings"
msgstr "Налаштування компонування"

#: deepnest/dialog.py
msgid "Cancel"
msgstr "Скасувати"

#: deepnest/dialog.py
msgid "Start Nesting"
msgstr "Почати компонування"

#: deepnest/dialog.py
msgid ""
"Nesting can consume significant memory and take a long time depending on the "
"number and complexity of shapes. It is recommended to start with a small "
"number of shapes before scaling up."
msgstr ""
"Компонування може споживати значну пам'ять і зайняти багато часу залежно від "
"кількості та складності форм. Рекомендується почати з невеликої кількості "
"форм перед масштабуванням."

#: deepnest/dialog.py
msgid "Spacing"
msgstr "Інтервал"

#: deepnest/dialog.py
msgid "Distance between nested shapes"
msgstr "Відстань між вкладеними формами"

#: deepnest/dialog.py
msgid "Constrain Rotation"
msgstr "Обмежити обертання"

#: deepnest/dialog.py
msgid "Keep parts in their original orientation"
msgstr "Зберегти оригінальну орієнтацію деталей"

#: deepnest/dialog.py
msgid "Allow Horizontal Flip"
msgstr "Дозволити горизонтальне відображення"

#: deepnest/dialog.py
msgid "Mirror parts horizontally for better fit"
msgstr "Відобразити деталі горизонтально для кращого розміщення"

#: deepnest/dialog.py
msgid "Allow Vertical Flip"
msgstr "Дозволити вертикальне відображення"

#: deepnest/dialog.py
msgid "Mirror parts vertically for better fit"
msgstr "Відобразити деталі вертикально для кращого розміщення"

#: deepnest/frontend.py
msgid "Auto Layout (Nesting)"
msgstr "Автоматичне компонування"

#: deepnest/backend.py
msgid "Nesting Layout"
msgstr "Компонування"
