#: deepnest/dialog.py
msgid "Nesting Layout Settings"
msgstr "Verschachtelungs-Einstellungen"

#: deepnest/dialog.py
msgid "Cancel"
msgstr "Abbrechen"

#: deepnest/dialog.py
msgid "Start Nesting"
msgstr "Verschachtelung starten"

#: deepnest/dialog.py
msgid ""
"Nesting can consume significant memory and take a long time depending on the "
"number and complexity of shapes. It is recommended to start with a small "
"number of shapes before scaling up."
msgstr ""
"Die Verschachtelung kann viel Speicher verbrauchen und je nach Anzahl und "
"Komplexität der Formen lange dauern. Es wird empfohlen, mit einer kleinen "
"Anzahl von Formen zu beginnen, bevor Sie skalieren."

#: deepnest/dialog.py
msgid "Spacing"
msgstr "Abstand"

#: deepnest/dialog.py
msgid "Distance between nested shapes"
msgstr "Abstand zwischen verschachtelten Formen"

#: deepnest/dialog.py
msgid "Constrain Rotation"
msgstr "Drehung einschränken"

#: deepnest/dialog.py
msgid "Keep parts in their original orientation"
msgstr "Teile in ursprünglicher Ausrichtung beibehalten"

#: deepnest/dialog.py
msgid "Allow Horizontal Flip"
msgstr "Horizontales Spiegeln erlauben"

#: deepnest/dialog.py
msgid "Mirror parts horizontally for better fit"
msgstr "Teile horizontal für bessere Passform spiegeln"

#: deepnest/dialog.py
msgid "Allow Vertical Flip"
msgstr "Vertikales Spiegeln erlauben"

#: deepnest/dialog.py
msgid "Mirror parts vertically for better fit"
msgstr "Teile vertikal für bessere Passform spiegeln"

#: deepnest/frontend.py
msgid "Auto Layout (Nesting)"
msgstr "Automatische Anordnung (Verschachtelung)"

#: deepnest/backend.py
msgid "Nesting Layout"
msgstr "Verschachteltes Layout"
