#: deepnest/dialog.py
msgid "Nesting Layout Settings"
msgstr "Configuración de diseño de anidamiento"

#: deepnest/dialog.py
msgid "Cancel"
msgstr "Cancelar"

#: deepnest/dialog.py
msgid "Start Nesting"
msgstr "Iniciar anidamiento"

#: deepnest/dialog.py
msgid ""
"Nesting can consume significant memory and take a long time depending on the "
"number and complexity of shapes. It is recommended to start with a small "
"number of shapes before scaling up."
msgstr ""
"El anidamiento puede consumir mucha memoria y tardar mucho tiempo "
"dependiendo del número y complejidad de las formas. Se recomienda comenzar "
"con un pequeño número de formas antes de escalar."

#: deepnest/dialog.py
msgid "Spacing"
msgstr "Espaciado"

#: deepnest/dialog.py
msgid "Distance between nested shapes"
msgstr "Distancia entre formas anidadas"

#: deepnest/dialog.py
msgid "Constrain Rotation"
msgstr "Restringir rotación"

#: deepnest/dialog.py
msgid "Keep parts in their original orientation"
msgstr "Mantener piezas en su orientación original"

#: deepnest/dialog.py
msgid "Allow Horizontal Flip"
msgstr "Permitir volteo horizontal"

#: deepnest/dialog.py
msgid "Mirror parts horizontally for better fit"
msgstr "Reflejar piezas horizontalmente para mejor ajuste"

#: deepnest/dialog.py
msgid "Allow Vertical Flip"
msgstr "Permitir volteo vertical"

#: deepnest/dialog.py
msgid "Mirror parts vertically for better fit"
msgstr "Reflejar piezas verticalmente para mejor ajuste"

#: deepnest/frontend.py
msgid "Auto Layout (Nesting)"
msgstr "Disposición automática (Anidamiento)"

#: deepnest/backend.py
msgid "Nesting Layout"
msgstr "Diseño de anidamiento"
