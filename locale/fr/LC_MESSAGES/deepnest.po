#: deepnest/dialog.py
msgid "Nesting Layout Settings"
msgstr "Paramètres de disposition en nidification"

#: deepnest/dialog.py
msgid "Cancel"
msgstr "Annuler"

#: deepnest/dialog.py
msgid "Start Nesting"
msgstr "Démarrer la nidification"

#: deepnest/dialog.py
msgid ""
"Nesting can consume significant memory and take a long time depending on the "
"number and complexity of shapes. It is recommended to start with a small "
"number of shapes before scaling up."
msgstr ""
"La nidification peut consommer beaucoup de mémoire et prendre beaucoup de "
"temps selon le nombre et la complexité des formes. Il est recommandé de "
"commencer avec un petit nombre de formes avant de passer à l'échelle."

#: deepnest/dialog.py
msgid "Spacing"
msgstr "Espacement"

#: deepnest/dialog.py
msgid "Distance between nested shapes"
msgstr "Distance entre les formes nichées"

#: deepnest/dialog.py
msgid "Constrain Rotation"
msgstr "Restreindre la rotation"

#: deepnest/dialog.py
msgid "Keep parts in their original orientation"
msgstr "Conserver les pièces dans leur orientation d'origine"

#: deepnest/dialog.py
msgid "Allow Horizontal Flip"
msgstr "Autoriser le retournement horizontal"

#: deepnest/dialog.py
msgid "Mirror parts horizontally for better fit"
msgstr "Retourner les pièces horizontalement pour un meilleur ajustement"

#: deepnest/dialog.py
msgid "Allow Vertical Flip"
msgstr "Autoriser le retournement vertical"

#: deepnest/dialog.py
msgid "Mirror parts vertically for better fit"
msgstr "Retourner les pièces verticalement pour un meilleur ajustement"

#: deepnest/frontend.py
msgid "Auto Layout (Nesting)"
msgstr "Disposition automatique (Nidification)"

#: deepnest/backend.py
msgid "Nesting Layout"
msgstr "Disposition en nidification"
